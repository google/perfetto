{
  "extends": "../../tsconfig.base.json",
  "include": [
    ".",
    "../types/vite.d.ts"
  ],
  "exclude": [
    "../gen/"
  ],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../../out/tsc/bigtrace",
    "types": ["*"],
    "lib": [
      "dom",
      "es2024",
      "dom.iterable",
    ],
    "paths": {
      "*" : ["./*", "../../node_modules/@tsundoku/micromodal_types/*"]
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
  }
}