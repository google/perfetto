packet {
  process_tree {
    processes {
      pid: 1
      ppid: 0
      cmdline: "init"
      uid: 0
    }
    processes {
      pid: 2
      ppid: 1
      cmdline: "system_server"
      uid: 1000
    }
  }
}

packet {
  clock_snapshot {
    clocks: {
      clock_id: 6 # BOOTTIME
      timestamp: 0
    }
    clocks: {
      clock_id: 4 # MONOTONIC_COARSE
      timestamp: 10
    }
  }
}

packet {
  trusted_packet_sequence_id: 999
  previous_packet_dropped: 1
  incremental_state_cleared: true
  timestamp: 30
  profile_packet {
    strings {
      iid: 1
      str: "f1"
    }
    frames {
      iid: 1
      function_name_id: 1
      mapping_id: 1
      rel_pc: 0x1000
    }
    callstacks {
      iid: 1
      frame_ids: 1
    }
    mappings {
      iid: 1
      path_string_ids: 1
      build_id: 1
    }
    process_dumps {
      pid: 2
      # MONOTONIC_COARSE; trace time = value - 10.
      timestamp: 30        # dump time (interval end) -> trace ts 20
      start_timestamp: 15  # interval start -> trace ts 5
      orig_sampling_interval_bytes: 1024
      sampling_interval_bytes: 1024
      samples {
        callstack_id: 1
        self_allocated: 1000
        alloc_count: 4
      }
    }
  }
}
