# Test flow events between GpuRenderStageEvents using event_wait_ids.
# Flow: softmax (GPU, queue 1) -> matmul (GPU, queue 2) via event_wait_ids

# Interned data: graphics context and hw queue / stage specs.
packet {
  trusted_uid: 9999
  trusted_packet_sequence_id: 1
  timestamp: 0
  interned_data {
    graphics_contexts {
      iid: 0
      pid: 42
      api: VULKAN
    }
    gpu_specifications {
      iid: 1
      name: "compute_0"
      description: "compute queue 0"
      category: COMPUTE
    }
    gpu_specifications {
      iid: 2
      name: "softmax"
      description: "softmax kernel"
      category: COMPUTE
    }
    gpu_specifications {
      iid: 3
      name: "compute_1"
      description: "compute queue 1"
      category: COMPUTE
    }
    gpu_specifications {
      iid: 4
      name: "matmul"
      description: "matmul kernel"
      category: COMPUTE
    }
  }
  sequence_flags: 1  # SEQ_INCREMENTAL_STATE_CLEARED
}

# GPU render stage event on queue 1: softmax kernel.
packet {
  trusted_uid: 9999
  trusted_packet_sequence_id: 1
  timestamp: 100
  gpu_render_stage_event {
    event_id: 1
    duration: 50
    hw_queue_iid: 1
    stage_iid: 2
    context: 0
    submission_id: 42
  }
  sequence_flags: 2  # SEQ_NEEDS_INCREMENTAL_STATE
}

# GPU render stage event on queue 2: matmul kernel, waited on softmax (event 1).
packet {
  trusted_uid: 9999
  trusted_packet_sequence_id: 1
  timestamp: 200
  gpu_render_stage_event {
    event_id: 2
    duration: 40
    hw_queue_iid: 3
    stage_iid: 4
    context: 0
    event_wait_ids: 1
  }
  sequence_flags: 2
}
