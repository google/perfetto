def snake_to_camel(name):
  """Convert snake_case to camelCase."""
  parts = name.split('_')
  return parts[0] + ''.join(p.capitalize() for p in parts[1:])


def resolve_ref(defs, ref_str):
  """Resolve a $ref like '#/$defs/group_by_op' to its definition."""
  assert ref_str.startswith('#/$defs/'), f'Unsupported $ref: {ref_str}'
  key = ref_str.split('/')[-1]
  return defs[key]


def classify_op(name, prop, defs):
  """Classify an operation property into a generation category."""
  if prop.get('type') == 'boolean' and prop.get('const') is True:
    return 'boolean_const'
  if prop.get('type') == 'string':
    return 'string'
  if prop.get('type') == 'integer':
    return 'integer'
  if prop.get('type') == 'array' and prop.get('items', {}).get('type') == 'string':
    return 'string_array'
  if (prop.get('type') == 'object'
      and prop.get('additionalProperties', {}).get('type') == 'string'):
    return 'string_map'
  if '$ref' in prop:
    return 'ref'
  # sort has oneOf [string, array[string]]
  if 'oneOf' in prop:
    types = [x.get('type') for x in prop['oneOf']]
    if 'string' in types and 'array' in types:
      return 'string_or_array'
  # window is object with additionalProperties: $ref
  if (prop.get('type') == 'object'
      and '$ref' in prop.get('additionalProperties', {})):
    return 'named_specs'
  return 'unknown'


