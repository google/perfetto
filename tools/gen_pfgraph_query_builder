    }""")
  return iface, method


def _gen_join_op(defn):
  iface = textwrap.dedent("""\
    interface JoinOpts {
      right: string;
      on: string;
      type?: 'INNER' | 'LEFT';
    }""")
  method = textwrap.dedent("""\
    join(opts: JoinOpts): PfgraphPipeline {
      let line = `.join(${opts.right}, on: ${opts.on}`;
      if (opts.type && opts.type !== 'INNER') {
        line += `, type: ${opts.type}`;
      }
      line += ')';
      this.ops.push(line);
      return this;
    }""")
  return iface, method


def _gen_span_join(defn):
  iface = textwrap.dedent("""\
    interface SpanJoinOpts {
      right: string;
      partition?: string[];
      type?: 'INNER' | 'LEFT';
    }""")
  method = textwrap.dedent("""\
    spanJoin(opts: SpanJoinOpts): PfgraphPipeline {
      let line = `.span_join(${opts.right}`;
      if (opts.partition && opts.partition.length > 0) {
        line += `, partition: [${opts.partition.join(', ')}]`;
      }
      if (opts.type && opts.type !== 'INNER') {
        line += `, type: ${opts.type}`;
      }
      line += ')';
      this.ops.push(line);
      return this;
    }""")
  return iface, method


