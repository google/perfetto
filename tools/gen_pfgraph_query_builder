    }""")
  method = textwrap.dedent("""\
    addColumns(opts: AddColumnsOpts): PfgraphPipeline {
      const cols = `[${opts.cols.join(', ')}]`;
      this.ops.push(
        `.add_columns(from: ${renderSourceRef(opts.from)}, on: ${opts.on}, cols: ${cols})`,
      );
