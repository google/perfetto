def gen_sources(defs, table_prop):
  """Generate source constructor functions from the table property."""
  lines = []

  # table('name') — always present (string variant)
  lines.append(textwrap.dedent("""\
    export function table(name: string): PfgraphPipeline {
      return new PfgraphPipeline(`table('${name}')`);
    }

    export function pipelineRef(name: string): PfgraphPipeline {
      return new PfgraphPipeline(name);
    }"""))

  # Process oneOf variants from the table property
  for variant in table_prop.get('oneOf', []):
    ref = variant.get('$ref', '')
    if 'sql_source' in ref:
      lines.append(textwrap.dedent("""\
    export function sql(expr: string): PfgraphPipeline {
      if (expr.includes('\\n')) {
        return new PfgraphPipeline(`sql('''${expr}''')`);
      }
      return new PfgraphPipeline(`sql('${expr}')`);
    }"""))
    elif 'slices_source' in ref:
      defn = resolve_ref(defs, ref)
      slices_props = defn['properties']['slices']['properties']
      fields = list(slices_props.keys())
      iface_fields = '\n'.join(
          f'  {f}?: string;' for f in fields)
      lines.append(f"""interface SlicesOpts {{
{iface_fields}
}}

export function slices(opts: SlicesOpts): PfgraphPipeline {{
  const parts: string[] = [];
{chr(10).join(f"  if (opts.{f} !== undefined) parts.push(`{f}: '${{opts.{f}}}'`);" for f in fields)}
  return new PfgraphPipeline(`slices(${{parts.join(', ')}})`);
}}""")
    elif 'interval_intersect_source' in ref:
      lines.append(textwrap.dedent("""\
    interface IntervalIntersectOpts {
      inputs: string[];
      partition?: string[];
    }

    export function intervalIntersect(opts: IntervalIntersectOpts): PfgraphPipeline {
      let line = `interval_intersect(${opts.inputs.join(', ')}`;
      if (opts.partition && opts.partition.length > 0) {
        line += `, partition: [${opts.partition.join(', ')}]`;
      }
      line += ')';
      return new PfgraphPipeline(line);
    }"""))
    elif 'union_source' in ref:
      lines.append(textwrap.dedent("""\
    export function union(...inputs: string[]): PfgraphPipeline {
      return new PfgraphPipeline(`union(${inputs.join(', ')})`);
    }"""))

  return '\n\n'.join(lines)


# ============================================================================
# Main generation
# ============================================================================


def generate(schema):
  defs = schema['$defs']
  op_props = defs['operation']['properties']

  # Skip 'table' — that's the source, not an operation.
  op_names = [name for name in op_props if name != 'table']

  interfaces = []
  methods = []
  seen_ifaces = set()

  for name in op_names:
    prop = op_props[name]
    cat = classify_op(name, prop, defs)

    if cat == 'boolean_const':
      methods.append(gen_boolean_const_method(name))
    elif cat == 'string':
      methods.append(gen_string_method(name))
    elif cat == 'integer':
      methods.append(gen_integer_method(name))
    elif cat == 'string_array':
      methods.append(gen_string_array_method(name))
    elif cat == 'string_or_array':
      methods.append(gen_string_or_array_method(name))
    elif cat == 'string_map':
      methods.append(gen_string_map_method(name))
    elif cat == 'named_specs':
      iface, method = gen_named_specs_method(name, prop, defs)
      if iface and iface not in seen_ifaces:
        interfaces.append(iface)
        seen_ifaces.add(iface)
      methods.append(method)
    elif cat == 'ref':
      if name not in COMPLEX_OPS:
        print(f'ERROR: Complex operation "{name}" has no rendering logic '
              f'in the generator. Add an entry to COMPLEX_OPS in '
              f'tools/gen_pfgraph_query_builder.',
              file=sys.stderr)
        sys.exit(1)
      ref_str = prop['$ref']
      defn = resolve_ref(defs, ref_str)
      iface, method = COMPLEX_OPS[name]['generate'](name, defn)
      if iface and iface not in seen_ifaces:
        interfaces.append(iface)
        seen_ifaces.add(iface)
      methods.append(method)
    else:
      print(f'ERROR: Cannot classify operation "{name}" (category: {cat}). '
            f'Update classify_op() in tools/gen_pfgraph_query_builder.',
            file=sys.stderr)
      sys.exit(1)

  # Indent all methods by 2 spaces (they go inside the class body)
  indented_methods = []
  for m in methods:
    indented = '\n'.join('  ' + line if line.strip() else '' for line in m.splitlines())
    indented_methods.append(indented)

  # Generate source constructors
  table_prop = op_props['table']
  sources_code = gen_sources(defs, table_prop)

  # Build the output
  out = []
  out.append(COPYRIGHT)

  # Operation list comment
  out.append(f'// Operations derived from schema: {", ".join(op_names)}')
  out.append('')

  # Interfaces
  out.append(
      '// ============================================================================')
  out.append(
      '// Interfaces for complex operation arguments')
  out.append(
      '// ============================================================================')
  out.append('')
  for iface in interfaces:
    out.append(f'export {iface}')
    out.append('')

  # GroupByResult helper interface
  out.append(textwrap.dedent("""\
    interface GroupByResult {
      agg(aggregations: Record<string, string>): PfgraphPipeline;
    }
    """))

  # PfgraphPipeline class
  out.append(
      '// ============================================================================')
  out.append(
      '// PfgraphPipeline — the fluent query builder')
  out.append(
      '// ============================================================================')
  out.append('')
  out.append('export class PfgraphPipeline {')
  out.append('  private readonly sourceLine: string;')
  out.append('  private readonly ops: string[] = [];')
  out.append('')
  out.append('  constructor(sourceLine: string) {')
  out.append('    this.sourceLine = sourceLine;')
  out.append('  }')

  for m in indented_methods:
    out.append('')
    out.append(m)

  # Render methods
  out.append('')
  out.append(textwrap.dedent("""\
      render(indent = 2): string {
        const pad = ' '.repeat(indent);
        const lines = [this.sourceLine, ...this.ops];
        return lines.map((line) => `${pad}${line}`).join('\\n');
      }

      renderAs(
        name: string,
        opts?: {type?: 'table' | 'view'; index?: string[]},
      ): string {
        let prefix = '';
        if (opts?.type === 'table') {
          prefix = '@table ';
        } else if (opts?.type === 'view') {
          prefix = '@view ';
        }
        let result = `${prefix}${name}:\\n${this.render()}`;
        if (opts?.index && opts.index.length > 0) {
          result += `\\n  .index(${opts.index.join(', ')})`;
        }
        return result;
      }"""))
  out.append('}')

  # Helper function
  out.append('')
  out.append(textwrap.dedent("""\
    function renderSourceRef(ref: string): string {
      if (ref.includes('.') || /^[a-z_][a-z0-9_]*$/i.test(ref)) {
        return `table('${ref}')`;
      }
      return ref;
    }"""))

  # Source constructors
  out.append('')
  out.append(
      '// ============================================================================')
  out.append(
      '// Source constructors — entry points for building pipelines')
  out.append(
      '// ============================================================================')
  out.append('')
  out.append(sources_code)

  # PfgraphModule class
  out.append('')
  out.append('')
  out.append(
      '// ============================================================================')
  out.append(
      '// Module builder — for rendering complete .pfgraph files')
  out.append(
      '// ============================================================================')
  out.append('')
  out.append(textwrap.dedent("""\
    export class PfgraphModule {
      private readonly moduleName: string;
      private readonly imports: string[] = [];
      private readonly declarations: string[] = [];

      constructor(moduleName: string) {
        this.moduleName = moduleName;
      }

      import(...modules: string[]): PfgraphModule {
        this.imports.push(...modules);
        return this;
      }

      addPipeline(
        name: string,
        pipeline: PfgraphPipeline,
        opts?: {type?: 'table' | 'view'; index?: string[]},
      ): PfgraphModule {
        this.declarations.push(pipeline.renderAs(name, opts));
        return this;
      }

      addFunction(decl: string): PfgraphModule {
        this.declarations.push(decl);
        return this;
      }

      render(): string {
        const lines: string[] = [];
        lines.push(`module ${this.moduleName}`);
        lines.push('');
        for (const imp of this.imports) {
          lines.push(`import ${imp}`);
        }
        if (this.imports.length > 0) {
          lines.push('');
        }
        lines.push(this.declarations.join('\\n\\n'));
        return lines.join('\\n');
      }
    }"""))

  return '\n'.join(out) + '\n'


def main():
  with open(SCHEMA_PATH) as f:
    schema = json.load(f)

  output = generate(schema)

  with open(OUTPUT_PATH, 'w') as f:
    f.write(output)

  print(f'Generated {OUTPUT_PATH}')
  print(f'  Schema: {SCHEMA_PATH}')
  op_count = len(
      [n for n in schema['$defs']['operation']['properties'] if n != 'table'])
  print(f'  Operations: {op_count}')


if __name__ == '__main__':
  main()
