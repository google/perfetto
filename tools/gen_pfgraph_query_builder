def gen_named_specs_method(name, prop, defs):
  """Generate method for window-like ops with named spec objects."""
  spec_ref = prop['additionalProperties']['$ref']
  spec_def = resolve_ref(defs, spec_ref)
  spec_props = spec_def.get('properties', {})
  required = set(spec_def.get('required', []))

  # Build the spec interface
  iface_name = _iface_name(name + '_spec')
  iface_fields = []
  for pname, pdef in spec_props.items():
    ts_type = 'string'
    if pdef.get('type') == 'array':
      ts_type = 'string[]'
    optional = '?' if pname not in required else ''
    iface_fields.append(f'  {snake_to_camel(pname)}{optional}: {ts_type};')

  iface = f'interface {iface_name} {{\n' + '\n'.join(iface_fields) + '\n}'

  camel = snake_to_camel(name)
  # Generate the method
  method = textwrap.dedent(f"""\
    {camel}(specs: Record<string, {iface_name}>): PfgraphPipeline {{
      for (const [specName, spec] of Object.entries(specs)) {{
        const parts: string[] = [spec.expr];
        if (spec.partition && spec.partition.length > 0) {{
          parts.push(`partition: [${{spec.partition.join(', ')}}]`);
        }}
        if (spec.order) {{
          parts.push(`order: ${{spec.order}}`);
        }}
        if (spec.frame) {{
          parts.push(`frame: ${{spec.frame}}`);
        }}
        this.ops.push(`.{name}(${{specName}}: ${{parts.join(', ')}})`);
      }}
      return this;
    }}""")
  return iface, method


