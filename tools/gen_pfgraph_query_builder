def _gen_group_by(defn):
  iface = ''
  method = textwrap.dedent("""\
    groupBy(...columns: string[]): GroupByResult {
      const groupCols = columns.join(', ');
      return {
        agg: (aggregations: Record<string, string>): PfgraphPipeline => {
          const aggEntries = Object.entries(aggregations)
            .map(([name, expr]) => `${name}: ${expr}`)
            .join(', ');
          this.ops.push(`.group_by(${groupCols})`);
          this.ops.push(`.agg(${aggEntries})`);
          return this;
        },
      };
    }""")
  return iface, method


