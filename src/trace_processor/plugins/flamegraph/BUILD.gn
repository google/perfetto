import("../../../../gn/perfetto.gni")
import("../../../../gn/test.gni")

assert(enable_perfetto_trace_processor_sqlite)

# The flamegraph computation, free of any SQLite dependency so it can be
# reused by future PerfettoSQL operator implementations.
source_set("flamegraph") {
  sources = [
    "flamegraph.cc",
    "flamegraph.h",
  ]
  deps = [
    "../../../../gn:default_deps",
    "../../../base",
    "../../../base/regex",
    "../../containers",
    "../../core/dataframe",
    "../../core/util",
  ]
}

if (enable_perfetto_benchmarks) {
  source_set("benchmarks") {
    testonly = true
    sources = [ "flamegraph_benchmark.cc" ]
    deps = [
      ":flamegraph",
      "../../../../gn:benchmark",
      "../../../../gn:default_deps",
      "../../../base",
      "../../containers",
      "../../core/dataframe",
    ]
  }
}

perfetto_unittest_source_set("unittests") {
  testonly = true
  sources = [ "flamegraph_unittest.cc" ]
  deps = [
    ":flamegraph",
    "../../../../gn:default_deps",
    "../../../../gn:gtest_and_gmock",
    "../../../base",
    "../../containers",
    "../../core/dataframe",
    "../../core/util",
  ]
}
