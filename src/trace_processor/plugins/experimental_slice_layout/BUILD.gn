import("../../../../gn/perfetto.gni")
import("../../../../gn/perfetto_tp_tables.gni")
import("../../../../gn/test.gni")

assert(enable_perfetto_trace_processor_sqlite)

perfetto_tp_tables("tables") {
  sources = [ "tables.py" ]
  deps = [ "../../tables:tables_python" ]
}

source_set("experimental_slice_layout") {
  sources = [
    "experimental_slice_layout.cc",
    "experimental_slice_layout.h",
    "experimental_slice_layout_impl.h",
  ]
  deps = [
    ":tables",
    "../../../../gn:default_deps",
    "../../../../include/perfetto/trace_processor:basic_types",
    "../../../base",
    "../../containers",
    "../../core/dataframe",
    "../../core/plugin",
    "../../storage",
    "../../tables",
    "../../types",
  ]
}

perfetto_unittest_source_set("unittests") {
  testonly = true
  sources = [ "experimental_slice_layout_unittest.cc" ]
  deps = [
    ":experimental_slice_layout",
    ":tables",
    "../../../../gn:default_deps",
    "../../../../gn:gtest_and_gmock",
    "../../../../include/perfetto/trace_processor:basic_types",
    "../../containers",
    "../../core/dataframe",
    "../../storage",
    "../../tables",
  ]
}
